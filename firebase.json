{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/sitemap.xml", "function": "sitemap" },
      { "source": "/prerender", "function": "prerender" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
