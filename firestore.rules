rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }

    function isAdminOrVerifier() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin', 'verifier'];
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isInvitedUser() {
      return request.auth != null
        && resource.data.email == request.auth.token.email;
    }

    match /workers/{workerId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdminOrVerifier();
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if isOwner(userId) && request.resource.data.role == 'client';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if request.auth != null
        && (resource.data.clientId == request.auth.uid || isAdminOrVerifier());
      allow create: if request.auth != null
        || (request.resource.data.keys().hasOnly([
          'clientId', 'clientName', 'clientPhone', 'clientWhatsapp', 'clientEmail',
          'serviceType', 'workType', 'workerId',
          'duration', 'startDate',
          'clientAddress',
          'requirements',
          'placementFee', 'placementFeePaid',
          'paynowPollUrl', 'paynowReference', 'paynowStatus', 'paynowPaidAt',
          'status', 'workerArrivedAt',
          'checkInSchedule', 'clientCheckIn',
          'replacementRequested', 'replacementReason',
          'createdAt', 'updatedAt',
        ]));
      allow update: if request.auth != null
        && (resource.data.clientId == request.auth.uid || isAdminOrVerifier());
      allow delete: if isAdmin();
    }

    match /applicants/{applicantId} {
      allow create: if true;
      allow read: if isAdminOrVerifier()
        || (request.auth != null
          && (resource.data.userId == request.auth.uid || resource.data.userId == ''));
      allow update: if isAdminOrVerifier()
        || (request.auth != null
          && resource.data.userId == ''
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'updatedAt']))
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'nationalIdUrl',
          'policeClearanceUrl',
          'documentUploadStatus',
          'documentUploadError',
          'updatedAt',
        ]);
      allow delete: if isAdmin();

      match /verifications/{verificationId} {
        allow read: if request.auth != null
          && (request.auth.uid == applicantId || isAdminOrVerifier());
        allow create, update: if isAdminOrVerifier();
      }
    }

    match /locationPages/{pageId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /transactions/{txnId} {
      allow read: if isOwner(resource.data.userId) || isAdminOrVerifier();
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    match /payouts/{payoutId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /verifierTasks/{taskId} {
      allow read: if isAdminOrVerifier();
      allow create: if isAdmin();
      allow update: if isAdminOrVerifier();
      allow delete: if isAdmin();
    }

    match /creatorSubmissions/{subId} {
      allow read: if isOwner(resource.data.userId) || isAdminOrVerifier();
      allow create: if request.auth != null;
      allow update: if isAdminOrVerifier();
      allow delete: if isAdmin();
    }

    match /sponsorships/{sponsorId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if request.auth != null;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /adCampaigns/{campaignId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if request.auth != null;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /invites/{inviteId} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isInvitedUser();
    }
  }
}
