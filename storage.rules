rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /workers/{workerId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin', 'verifier']
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*|application/pdf');
    }

    match /verification/{verifierId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'verifier'];
      allow delete: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /applicants/{applicantId}/{allPaths=**} {
      allow read: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'verifier', 'applicant'];
      allow create: if request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*|application/pdf');
      allow update, delete: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'verifier'];
    }

    match /documents/{allPaths=**} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'verifier'];
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
